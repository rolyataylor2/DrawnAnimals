
<style>
    .profileTable {
        color: black;
        border: 20px solid transparent;
        table-layout:fixed;
        overflow:hidden; 
        width:100%;
    }
    .profileTable td {
        padding: 6px;
        position: relative;
        vertical-align: top;
    }
    .profileTable > tbody > tr:nth-child(1) > td:nth-child(1) {
        width: 300px;
        height: 300px;
    }
    .profileTable > tbody > tr:nth-child(1) > td:nth-child(1) > img {
        position: absolute;
        width: 300px;
        height: 300px;
        bottom:-30px;
    }
    .profileTable > tbody > tr:nth-child(1) > td:nth-child(1) > div:nth-child(2) {
        height: 31px;
        position: absolute;
        bottom: 0px;
        left: 10px;
    }
    .profileTable > tbody > tr:nth-child(1) > td:nth-child(1) > div:nth-of-type(1)  {
        width: 100%;
        height: 16px;
        overflow: hidden;
        padding: 5px;
        margin: -5px;
        position: absolute;
        bottom: 16px;
        left: 10px;
    }
    .profileTable > tbody > tr:nth-child(1) > td:nth-child(1) > div:nth-of-type(2) {
position: absolute;
top: -15px;
width: 100%;
height: 43px;
padding: 10px;
background-color: rgba(0, 0, 0, 0.72);
border-radius: 3px;
font-weight: bolder;
color: white;
font-size: 16px;
    }
    .profileTable > tbody > tr:nth-child(1) > td:nth-child(2) > div {
        width: 90%;  min-height: 75px;  max-height: 140px;  margin: 0 auto;  border-bottom: 2px dotted white;  border-radius: 10px;  padding: 10px;  text-align: center;  color: black;  font-weight: bold;
    }
    .profileTable > tbody > tr:nth-child(1) > td:nth-child(2) > div:nth-child(1) {
        width: 90%;
        min-height: 75px;
        max-height: 200px;
        margin: 0 auto;
        background-color: white;
        border-radius: 2px;
        padding: 10px;
        text-align: left;
        color: black;
        font-weight: bold;
        box-shadow: 0 0 3px;
        overflow: auto;
    }
    .profileTable > tbody > tr:nth-child(1) > td:nth-child(1) > div > div:nth-child(4) {
        font-size: 10px;
        text-align: right;
    }
    
</style>

<style>
    .column {
        float:left;
        display:block;
        margin:0px;
        min-height:100px;
    }
    .column.two {
        width:48%;
        padding:1%;
    }
    @media only screen and (max-width: 900px) {
        .column.two {
            width:98%
        }
    }
    .column.three {
        width:31%;
        padding:3%;
    }
    @media only screen and (max-width: 900px) {
        .column.three {
            width:98%
        }
    }
</style>

<div class="body">
    <div class="column two">
        nothing
    </div>
    <div class="column two">
        nothing
    </div>
    
    <table class="profileTable">
        <tr>
            <td>
                <img width="300" src="{{ IMAGE }}"/>
                <div>
                    <img src="http://img.drawnimals.com/interface/type{{ TYPE0 }}.png"/>
                    <img src="http://img.drawnimals.com/interface/type{{ TYPE1 }}.png"/>
                </div>
                <div class='Editable'>
                    <div class='EditButton'>Edit</div>
                    <div style="font-size:9px;">Rolyataylor2's</div>
                    {{ NICKNAME }} LV. {{ LEVEL }}
                    <div style="font-size:10px; text-align: right;">the {{ PAINT }} {{ SPECIES }}</div>
                </div>
            </td>
            <td>
                <div class='Editable' style="width:90%; min-height:75px; max-height:140px; margin:0 auto; border-bottom:2px dotted white; border-radius:10px; padding:10px;text-align:center; color:black; font-weight:bold;">
                    <div class='EditButton'>Edit</div>
                    <div style='width:100%'>About Me:</div>
                {% if ABOUTME|length == 0 %}
                    This Drawnimal has no story...
                {% else %}
                    {{ ABOUTME }}
                {% endif %}
                </div>
            </td>
        </tr>
        <tr>
            <td>
                {{ STATS_CHART|raw }}
                <div style="width: 100%;
                        padding: 10px 0px;
                        height: 43px;
                        background-color: #1F1F1F;
                        border-radius: 4px;
                        margin: 4px 0px;">
                {{ HPGUAGE|raw }}
                </div>
                {{ STATS_FULL|raw }}

            </td>
            <td>
                
            things needed (Gender, Original trainer box (date caught, Location Caught), Trainer Box (date recieved), Move Box, Awards box, battle history)
            {{ MOOD|raw }}
            </td>
        </tr>
    </table>
</div>
<script>
    var html = '<div class="button" class="back" onclick="MENU.Game.Play();">&lt; To Game</div><div class="title">Drawnimal Lookup</div><ul onclick="$(this).toggleClass(\'open\');">';
    html += '<li class="title">View</li>';
    html += '<li class="selected" onclick="">Main Page</li>';
    html += '<li onclick="">Statistics</li>';
    html += '<li onclick="">Awards</li>';
    html += '<li onclick="">Family Tree</li>';
    html += '<li class="title">Options</li>';
    html += '<li onclick="">Offer Trade</li>';
    html += '<li onclick="">Pet</li>';
    html += '<li onclick="">Release</li>';
    html += '</ul>';
    $('#settingsMenu').html(html);
    $('li:not(.title)').attr('onclick', function () {
        return $(this).attr('onclick') + " $(this).addClass('selected').siblings().removeClass('selected');";
    });
</script>