{# empty Twig template #}
<style>
    #MainWindowContents { bottom:0px; }
    .loginContainer {
        position:absolute;
        top: 50%;
        left: 50%;
        width: 200px;
        height: 250px;
        margin-left: -100px;
        margin-top: -150px;
        text-align:center; 

        box-shadow:inset 0px 1px 0px 0px #ffffff, 0 0 10px black;
        background:-webkit-gradient( linear, left top, left bottom, color-stop(0.05, #f9f9f9), color-stop(1, #e9e9e9) );
        background:-moz-linear-gradient( center top, #f9f9f9 5%, #e9e9e9 100% );
        filter:progid:DXImageTransform.Microsoft.gradient(startColorstr='#f9f9f9', endColorstr='#e9e9e9');
        background-color:#f9f9f9;
        border-radius:12px;
        text-indent:0px;
        border:2px solid #dcdcdc;
        display:inline-block;
        color:#666666;
        font-family:Arial;
        font-size:13px;
        font-weight:bold;
        font-style:normal;
        text-decoration:none;
        text-align:center;
        text-shadow:1px 1px 0px #ffffff;
    }
    .loginContainer label {
        display: block;
        width: 80%;
        margin: 10px auto;
    }
    .loginContainer label input {
        width:80%; margin:0px auto;
    }
    .loginContainer .loginTitle {
        width: 60%;
        font-size: 10px;
        padding: 10px;
        margin: 0 auto;
    }
    .loginContainer button { width:40%; margin:4%;}

</style>
<form class="loginContainer" onsubmit="MENU.popup.url = 'ajax/trainer/setup/pop.login.php';
        return MENU.popup.reloadForm($(this));">
    <div class="loginTitle">Login Below</div>
    <label>Username:<input type="text" name="username"/></label>
    <label>PassKey:<input type="password" name="password"/></label>
    <input type="hidden" name="token" value="{{ TOKEN }}"/>
    <button>Continue</button>
    <button onclick="MENU.Trainer.Setup.AccountRegister();
            return false;">New Game</button>
</form>
<script>
    $('#SiteWrapper').addClass('blackOut');
</script>