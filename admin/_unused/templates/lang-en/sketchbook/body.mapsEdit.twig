                    }
                    if (dataset[i.x-1] !== void 0 && nodes[i.x-1][i.y] !== false && dataset[i.x-1][i.y] === starting) {
                        dataset[i.x-1][i.y] = option;
                        nodes[i.x-1][i.y] = false;
                        Q.push({ x:i.x-1, y:i.y });
                    }
                    if (dataset[i.x][i.y+1] !== void 0 && nodes[i.x][i.y+1] !== false && dataset[i.x][i.y+1] === starting) {
                        dataset[i.x][i.y+1] = option;
                        nodes[i.x][i.y+1] = false;
                        Q.push({ x:i.x, y:i.y+1 });
                    }
                    if (dataset[i.x][i.y-1] !== void 0 && nodes[i.x][i.y-1] !== false && dataset[i.x][i.y-1] === starting) {
                        dataset[i.x][i.y-1] = option;
                        nodes[i.x][i.y-1] = false;
                        Q.push({ x:i.x, y:i.y-1 });
                    }
                    
                }
                $(this).data('set',dataset);
                $(this).trigger('renderDataset');
                
            })
            .on('renderDataset',function() {
                var context = $('.mapeditor > tbody > tr > td:nth-of-type(1) > canvas:last-of-type')[0].getContext('2d');
                context.clearRect(0,0,640,640);
                context = $('.mapeditor > tbody > tr > td:nth-of-type(1) > canvas.mapObject')[0].getContext('2d');
                var dataset = $(this).data('set');
                var images = $('.mapeditor > tbody > tr > td:nth-of-type(2) > div:nth-of-type(2) > div.selected > div > div > img');
                images.sort(function (a, b) {
                    var contentA =parseInt( $(a).attr('data-id'));
                    var contentB =parseInt( $(b).attr('data-id'));
                    return (contentA < contentB) ? -1 : (contentA > contentB) ? 1 : 0;
                 });
                var img = 0;
                context.clearRect(0,0,640,640);
                var xx = 64, yy = 64;
                while(xx--) {
                    while(yy--) {
                        if (dataset[xx][yy] !== 0) {
                            if (dataset[xx][yy] !== false) {
                                img = images.get(dataset[xx][yy]-1);
                                context.drawImage(img, xx*10,yy*10,img.width,img.height);
                            }
                        }
                    }
                    yy=64;
                }
                $(this).data('set',dataset);
            }).data('lastx',0).data('lasty',0).trigger('renderDataset');
            
            
            
    $('.mapeditor > tbody > tr > td:nth-of-type(1) > canvas:last-of-type').mousedown(function(e) {
        $(this).data('mousedown',true);
        var x = ~~((e.pageX - $(this).offset().left)/10);
        var y = ~~((e.pageY - $(this).offset().top)/10);
        var option = $('.mapeditor > tbody > tr > td:nth-of-type(2) > div:nth-of-type(2) > div.selected > div > div.selected').data('tool-option');
        $($('.mapeditor > tbody > tr > td:nth-of-type(2) > div:nth-of-type(2) > div.selected').data('map'))
                .trigger($('.mapeditor > tbody > tr > td:nth-of-type(2) > div:first-of-type > button.selected').data('tool')+'Start',[x,y,option]);
    }).mousemove(function(e) {
        var x = ~~((e.pageX - $(this).offset().left)/10);
        var y = ~~((e.pageY - $(this).offset().top)/10);
        var option = $('.mapeditor > tbody > tr > td:nth-of-type(2) > div:nth-of-type(2) > div.selected > div > div.selected').data('tool-option');
        $('.mapeditor > tbody > tr > td:nth-of-type(1) > img').css('left',(x*10)+'px').css('top',(y*10)+'px');
        if ($(this).data('mousedown') !== true) return;
        $($('.mapeditor > tbody > tr > td:nth-of-type(2) > div:nth-of-type(2) > div.selected').data('map'))
                .trigger($('.mapeditor > tbody > tr > td:nth-of-type(2) > div:first-of-type > button.selected').data('tool'),[x,y,option]);
    }).mouseup(function(e) {
        $(this).data('mousedown',false);
        var x = ~~((e.pageX - $(this).offset().left)/10);
        var y = ~~((e.pageY - $(this).offset().top)/10);
        var option = $('.mapeditor > tbody > tr > td:nth-of-type(2) > div:nth-of-type(2) > div.selected > div > div.selected').data('tool-option');
        $($('.mapeditor > tbody > tr > td:nth-of-type(2) > div:nth-of-type(2) > div.selected').data('map'))
                .trigger($('.mapeditor > tbody > tr > td:nth-of-type(2) > div:first-of-type > button.selected').data('tool')+'End',[x,y,option]);
    });
    $(document).mouseup(function(){
        $('.mapeditor > tbody > tr > td:nth-of-type(1) > canvas.mapOverlay').data('mousedown',false);
    });
</script>