
<form>
    <table class='entitytable'>
        <thead>
            <tr>
                <td style='width:300px;'>{{ DRAWNIMAL.DATA.species|capitalize }}</td>
                <td>
                    Created By: {{ DRAWNIMAL.creator }}<br/>
                    <div data-parent='.abilities'>Items/Abilities</div>
                    <div data-parent='.appearence'>Appearence</div>
                    <div data-parent='.evolvecode'>Evolve Code</div>
                    <div data-parent='.moveset'>Move Set</div>
                    <div data-parent='.images'>Images</div>
                    <div class='selected' data-parent='.basestats'>Base Stats</div>
                </td>
            </tr>
        </thead>
        <tbody>
            <tr>
                <td>
                    <img width='300' src='{{ DRAWNIMAL.imageurl }}'/>
                    {% if DRAWNIMAL.DATA.approved == 0 %} <center>This Drawnimal is Still Pending Approval.</center> {% elseif DRAWNIMAL.DATA.approved == 2 %} <center>This Drawnimal cannot be approved...</center> {% endif %}
                    
                    <table class='datatable red' style="margin-bottom:30px;" border="1">
                        <thead><tr><td>Sub Species</td><td></td></tr></thead>
                        <tbody>
                            {% for i in DRAWNIMAL.FORMS %}
                                <tr>
                                    <td><a href='#' onclick='MENU.Sketchbook.DrawnimalEdit("id={{ i.id }}");'>{{ DRAWNIMAL.DATA.species|capitalize }}</a></td>
                                    <td>{{ i.form }}</td>
                                </tr>
                            {% endfor %}
                        </tbody>
                        <tfoot>
                            <tr><td><button>Create New Form</button></td><td></td></tr>
                        </tfoot>
                    </table>
                    <input type='submit' value='Save' style='width:40%; margin:0 6%;'/>
                    <input type='submit' value='Request Delete'  style='width:40%;' onclick='confirm("Are you sure you want to delete this Drawnimal?\nThere is no way to undo this action. Your Drawnimal will be lost forever!");'/>
                    <div class="progressbar"><div class="bar"></div><div class="percent">0%<div></div></div></div>
        </td>
        <td>
            <div class='container basestats'>
                <table class='datatable' border="1">
                    <thead><tr><td>Type (Primary)</td><td>Type (Secondary)</td></tr></thead>
                    <tbody>
                        <tr>
                            <td>
                                <select name="type_primary">
                                    {% for type in TYPES %}<option value="{{ loop.index0 }}" {% if loop.index0==DRAWNIMAL.DATA.type_0 %}selected="true"{% endif %}>{{ type }}</option>{% endfor %}
                                </select>
                            </td>
                            <td>
                                <select name="type_secondary">
                                    {% for type in TYPES %}<option value="{{ loop.index0 }}" {% if loop.index0==DRAWNIMAL.DATA.type_1 %}selected="true"{% endif %}>{{ type }}</option>{% endfor %}
                                </select>
                            </td>
                        </tr>
                    </tbody>
                </table>
                <hr/>
                <table class='datatable' border="1">
                    <thead>
                        <tr>
                            <td>HP</td>
                            <td>ATK</td>
                            <td>DEF</td>
                            <td>SPATK</td>
                            <td>SPDEF</td>
                            <td>SPEED</td>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td><input name="bs_hp" type='text' value='{{ DRAWNIMAL.DATA.bs_hp }}'/></td>
                            <td><input name="bs_atk" type='text' value='{{ DRAWNIMAL.DATA.bs_atk }}'/></td>
                            <td><input name="bs_def" type='text' value='{{ DRAWNIMAL.DATA.bs_def }}'/></td>
                            <td><input name="bs_spatk" type='text' value='{{ DRAWNIMAL.DATA.bs_spatk }}'/></td>
                            <td><input name="bs_spdef" type='text' value='{{ DRAWNIMAL.DATA.bs_spdef }}'/></td>
                            <td><input name="bs_speed" type='text' value='{{ DRAWNIMAL.DATA.bs_speed }}'/></td>
                        </tr>
                    </tbody>
                </table>
                <table class="datatable" border="1">
                    <thead>
                        <tr><td>Hunger</td><td>Energy</td><td>Friendship</td></tr>
                    </thead>
                    <tbody>
                    <td><input name="bs_hunger" type='text' value='{{ DRAWNIMAL.DATA.bs_hunger }}'/></td>
                    <td><input name="bs_energy" type='text' value='{{ DRAWNIMAL.DATA.bs_energy }}'/></td>
                    <td><input name="bs_friend" type='text' value='{{ DRAWNIMAL.DATA.bs_friendship }}'/></td>
                    </tbody>
                </table>
                <hr/>
                <table class='datatable' border="1">
                    <thead>
                        <tr>
                            <td>EXP Reward</td>
                            <td>HP EV</td>
                            <td>ATK EV</td>
                            <td>DEF EV</td>
                            <td>SPATK EV</td>
                            <td>SPDEF EV</td>
                            <td>SPEED EV</td>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td><input name="ev_exp" type='text' value='{{ DRAWNIMAL.DATA.bs_exp }}'/></td>
                            <td><input name="ev_hp" type='text' value='{{ DRAWNIMAL.DATA.ev_hp }}'/></td>
                            <td><input name="ev_atk" type='text' value='{{ DRAWNIMAL.DATA.ev_atk }}'/></td>
                            <td><input name="ev_def" type='text' value='{{ DRAWNIMAL.DATA.ev_def }}'/></td>
                            <td><input name="ev_spatk" type='text' value='{{ DRAWNIMAL.DATA.ev_spatk }}'/></td>
                            <td><input name="ev_spdef" type='text' value='{{ DRAWNIMAL.DATA.ev_spdef }}'/></td>
                            <td><input name="ev_speed" type='text' value='{{ DRAWNIMAL.DATA.ev_speed }}'/></td>
                        </tr>
                    </tbody>
                </table>
                <hr/>
                <table class='datatable' border="1">
                    <thead><tr><td>Description</td><td>Scientific Classafication</td></tr></thead>
                    <tbody>
                        <tr>
                            <td><textarea name='description'>{{ DRAWNIMAL.DATA.description }}</textarea></td>
                            <td>
                                <table style='width:100%; height:100%;' border="1">
                                <tbody>
                                    <tr>
                                        <td>Class<input type="text" name='genus_class' value="{{ DRAWNIMAL.DATA.genus_class }}"/></td>
                                    </tr>
                                    <tr>
                                        <td>Order<input type="text" name='genus_order' value="{{ DRAWNIMAL.DATA.genus_order }}"/></td>
                                    </tr>
                                    <tr>
                                        <td>Family<input type="text" name='genus_family' value="{{ DRAWNIMAL.DATA.genus_family }}"/></td>
                                    </tr>
                                </tbody>
                                </table>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
            <div class='container images'>
                <table id="imageTable" class="datatable" border='1'>
                    <thead>
                        <tr><td>Image</td><td>Gender</td><td>Paint Color</td><td>Delete</td></tr>
                    </thead>
                    <tbody>
                        {% for url in DRAWNIMAL.IMAGES %}
                        <tr>
                            <input name="imageGender[]" value="{{ url.gender }}" type="hidden"/>
                            <input name="imagePaint[]" value="{{ url.paint }}" type="hidden"/>
                            <td>
                                <img src="http://img.drawnimals.com/u/d/{{ url.filename }}" height="64" width="64" onclick="$(this).next().click();"/>
                                <input style="display:none;" name="image_g_{{ url.gender }}_p_{{ url.paint }}" type="file">
                                {% if url.approved == false %}
                                    (pending approval)
                                {% else %}
                                    (approved)
                                {% endif %}
                            </td>
                            {% set GENDERS = ['Male','Female','','All'] %}
                            <td>{{ GENDERS[url.gender] }}</td>
                            <td>{{ url.paint }}</td>
                            <td>
                                {% if url.gender == 3 and url.paint == '' %}
                                    Cannot Delete
                                {% else %}
                                    <button type='button' onclick='$(this).parent().parent().remove();'>Remove</button>
                                {% endif %}
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                    <tfoot>
                        <tr>
                            <td>(Upload image by clicking it in the list)</td>
                            <td>
                                <select id="ImageGender">
                                    <option value="3">All</option>
                                    <option value="0">Male</option>
                                    <option value="1">Female</option>
                                </select>
                            </td>
                            <td>
                                <select id="ImagePaint" >
                                    <option value="">No Paint</option>
                                    {% for p in PAINT %}
                                    <option>{{ p|capitalize }}</option>
                                    {% endfor %}
                                </select>
                            </td>
                            
                            <td><button type='button' id="ImageAdd">Add Image</button></td>
                        </tr>
                    </tfoot>
                </table>
                <sub>
                    These are the images that will be used in the game. Drawnimals can come in many variations 
                    including Male/Female differences as well as being painted a different color. The Paint Color 
                    dropdown shows different paint styles used in the game. The more variations you upload the more
                    unique your Drawnimal will be. Many people seek Drawnimals in their favorite colors.
                </sub>
                <script>
                    $('#imageTable > tfoot > tr > td > button').click(function() {
                        var gender = $('#imageTable > tfoot > tr > td:nth-of-type(2) > select').val();
                        var paint = $('#imageTable > tfoot > tr > td:nth-of-type(3) > select').val();
                        
                        var html = '<tr>';
                        html += '<input type="hidden" name="imageGender[]" value="'+gender+'"/>';
                        html += '<input type="hidden" name="imagePaint[]" value="'+paint+'"/>';
                        html += '<td><img width="64" height="64" src="http://img.drawnimals.com/d/blank.png" onclick="$(this).next().click();"/><input type="file" name="image_g_'+gender+'_p_'+paint+'" style="display:none;"/></td>';
                        html += '<td>'+$('#imageTable > tfoot > tr > td:nth-of-type(2) > select > option:selected').text()+'</td>';
                        html += '<td>'+paint+'</td>';
                        html += '<td><button type="button" onclick="$(this).parent().parent().remove();">Remove</button></td>';
                        html += '</tr>';
                        $('#imageTable > tbody').append(html);
                    });
                </script>
            </div>
            <div class='container moveset'>
                {{ DRAWNIMAL.LEARNSETTABLE|raw }}
                <sub>
                    This is a list of all the moves that can be learned by this Drawnimal, Some moves are learned by 
                    reaching the level indicated, if the Level = 0 then the move can be learned by a TM.
                    if the level = 1 then this drawnimal will know the move when hatched from an egg. 
                    if more then 4 moves are present at level 1 then they are decided randomly.
                    Invalid Move Names will not be saved.
                </sub>
            </div>
            <div class='container evolvecode'>
                {{ evolveTable|raw }}
                <sub>
                    This code is executed everytime a Drawnimal Levels up, is Traded, or a evolution item is used on it. 
                    In this code you can have this Drawnimal evolve into any other Drawnimal that you have created. 
                    You cannot evolve a Drawnimal into someone elses Drawnimal.
                </sub>
            </div>
            <div class='container appearence'>
                {{ appearenceTable|raw }}
                <sub>
                    This code is used to place Drawnimals into the game, Use this code to determine the conditions for 
                    which your Drawnimal is spawned into the game, if you do not want your drawnimal to be spawned in 
                    the game simply leave this blank, or put in [Appear 0%]
                </sub>
            </div>
            <div class='container abilities'>
                <h2>Abilities</h2>
                {{ DRAWNIMAL.ABILITYTABLE|raw }}
                <h2>Items</h2>
                {{ DRAWNIMAL.ITEMSTABLE|raw }}
            </div>
        </td>
        </tr>
        </tbody>
    </table>
</form>
<script>
    $('table.entitytable > thead > tr > td > div').click(function() {
        $('table.entitytable > thead > tr > td > div').removeClass('selected');
        $('table.entitytable > tbody > tr > td > .container').hide();
        $($(this).data('parent')).show();
        $(this).addClass('selected');
    });
</script>