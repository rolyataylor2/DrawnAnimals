<form onsubmit="MENU.body.reloadForm($(this)); return false;">
    <table class="entitytable">
        <thead>
            <tr>
                <td style="width:300px;">{{ ENV.name }}</td>
                <td>
                    Created By {{ ENV.creator }}<br/><br/>
                    <div>Images</div>
                </td>
            </tr>
        </thead>
        <tbody>
            <tr>
                <td>

                    <table class="datatable">
                        <thead><tr><td>Description</td></tr></thead>
                        <tbody><tr><td><textarea name="description"></textarea></td></tr></tbody>
                    </table>
                    <table class="datatable">
                        <thead><tr><td>Color</td></tr></thead>
                        <tbody><tr><td><input name="color" type="hidden"/><div style="width:196px; margin:0 auto;"></div></td></tr></tbody>
                    </table>
                    <sub>This color will be used in the map editor to show this environment, Try to choose a unique color.</sub>
                    <input type='submit' value='Save' style='width:40%; margin:0 6%;'/>
                    <input type='submit' value='Request Delete'  style='width:40%;' onclick='confirm("Are you sure you want to delete this Drawnimal?\nThere is no way to undo this action. Your Drawnimal will be lost forever!");'/>
                    <div class="progressbar"><div class="bar"></div><div class="percent">0%<div></div></div></div>
                </td>
                <td>
                    <div class='container'>
                        <table class="datatable">
                            <thead><tr><td>Ground Tiles</td><td>Water Tiles</td><td>WildPatch Tiles</td></tr></thead>
                            <tbody>
                                <tr>
                                    <td>
                                        <div class="imageUploadWithCollision">
                                             <img src="http://img.drawnimals.com/d/blank.png"/>
                                        </div>
                                    </td>
                                    <td>
                                        <div class="imageUploadWithCollision">
                                             <img src="http://img.drawnimals.com/d/blank.png"/>
                                        </div>
                                    </td>
                                    <td>
                                        <div class="imageUploadWithCollision">
                                             <img src="http://img.drawnimals.com/d/blank.png"/>
                                        </div>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                        <table class="datatable">
                            <thead><tr><td>Bush</td><td>Small Tree</td><td>Medium Tree</td><td>Large Tree</td><td>Giant Tree</td></tr></thead>
                            <tbody>
                                <tr>
                                    <td>
                                        <div class="imageUploadWithCollision bush">
                                            <img src="http://drawnimals.com/img/u/e/1/bush.png"/>
                                            <div></div>
                                        </div>
                                        <sub>Collision of (64 x 32) pixels</sub>
                                    </td>
                                    <td>
                                        <div class="imageUploadWithCollision smallTree">
                                            <img src="http://drawnimals.com/img/u/e/1/smalltree.png"/>
                                            <div></div>
                                        </div>
                                        <sub>Collision of (32 x 32) pixels</sub>
                                    </td>
                                    <td>
                                        <div class="imageUploadWithCollision mediumTree">
                                            <img src="http://drawnimals.com/img/u/e/1/mediumtree.png"/>
                                            <div></div>
                                        </div>
                                        <sub>Collision of (64 x 64) pixels</sub>
                                    </td>
                                    <td>
                                        <div class="imageUploadWithCollision largeTree">
                                            <img src="http://img.drawnimals.com/d/blank.png"/>
                                            <div></div>
                                        </div>
                                        <sub>Collision of (96 x 96) pixels</sub>
                                    </td>
                                    <td>
                                        <div class="imageUploadWithCollision giantTree">
                                            <img src="http://img.drawnimals.com/d/blank.png"/>
                                            <div></div>
                                        </div>
                                        <sub>Collision of (128 x 128) pixels</sub>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </td>
            </tr>
        </tbody>
    </table>
</form>
<style>
    .imageUploadWithCollision {
        position:relative;
        display: table-cell;
        vertical-align: bottom;
        height:180px;
        width:200px;
    }
    .imageUploadWithCollision div {
        position: absolute;
        width: 64px;
        height: 32px;
        background-color: rgba(235, 21, 21, 0.46);
        bottom: 0px;
        left: 50%;
        margin-left: -32px;
    }
    .imageUploadWithCollision img {
        display:block;
        margin:0 auto;
        max-width:128px;
        max-height:180px;
        vertical-align: bottom;
    }
    .imageUploadWithCollision.smallTree div {
        width:32px;
        margin-left:-16px;
    }
    .imageUploadWithCollision.mediumTree div {
        width:64px; height:64px;
        margin-left:-32px;
    }
    .imageUploadWithCollision.largeTree div {
        width:96px; height:96px;
        margin-left:-48px;
    }
    .imageUploadWithCollision.giantTree div {
        width:128px; height:128px;
        margin-left:-64px;
    }
    
</style>
<script>
    $.farbtastic('table.entitytable > tbody > tr > td:nth-of-type(1) > .datatable:nth-of-type(2) > tbody > tr > td > div')
            .linkTo(function callback(color) { 
                $('table.entitytable > tbody > tr > td:nth-of-type(1) > .datatable:nth-of-type(2) > tbody > tr > td > input').val(color);
            }).setColor('{{ ENV.color }}');
</script>