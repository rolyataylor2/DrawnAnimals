<h1>Release Drawnimal</h1>
<sub>By clicking ok your Drawnimal will be released into the wild... Never to be seen again...</sub>
{% if SCRIPT_OUTPUT|length > 0 %}
    <center>{{ SCRIPT_OUTPUT }}</center>
{% else %}
    Are you sure you want to part ways with {{ PETNAME }}?<br/>
    <form onsubmit="return MENU.popup.reloadForm($(this));">
        {% if SCRIPT_ERROR|length > 0 %}
            <div class='error'>{{ SCRIPT_ERROR|raw }}</div>
        {% endif %}
        <input type="hidden" name="token" value="{{ TOKEN }}"/>
        <input type="hidden" name="pid" value="{{ PID }}"/>
        <input type="submit" value="Yes"/>
    </form>
{% endif %}