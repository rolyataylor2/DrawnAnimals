{# empty Twig template #}
<style>
    .error {width:90%; margin:5px 5%; background-color:rgba(200,100,100,0.3); border:1px solid red;}
    .success {width:90%; margin:5px 5%; background-color:rgba(100,200,100,0.3); border:1px solid lime;}
</style>
<h1>Register a New Player</h1>
<sub>
    If you do not already have an account create a new one here, 
    you are allowed 3 accounts per email, 
    please read the terms and conditions by clicking here.
</sub>
{% if SCRIPT_OUTPUT != '' %}
    <div class='error'>{{ SCRIPT_OUTPUT }}</div>
{% endif %}
{% if SCRIPT_SUCCESS != '' %}
    <div class='success'>{{ SCRIPT_SUCCESS }}</div>
{% else %}
    <form id="RegisterIndex" onsubmit="return MENU._popupReload($('#RegisterIndex').serialize());">
        <label>Username: <input name="username" type="text" value="{{ USERNAME }}" /></label>
        <label>Password<input name="password" type="text" /></label>
        <label>Confirm Password<input name="passwordconfirm" type="text" /></label>
        <label>Email<input name="email" type="text" value="{{ EMAIL }}"/></label>
        <label>Confirm Email<input name="emailconfirm" type="text" value="{{ EMAIL }}"/></label>
        <label>Captcha <input name="captcha" type="text" value=""/></label>
        <label>I agree to the site rules <input name="agree" type="checkbox"/></label>
        <input name="token" type="hidden" value="{{ TOKEN }}"/>
        <input type="submit" value="Create New Player"/>
    </form>
{% endif %}