    <script>
        function SlideShowNext() {
            var elm = $('.slider');
            if (elm.data('left') > 0) return;
            elm.data('left',elm.data('left')+480);
            elm.css('left',elm.data('left')+'px');
        };
        function SlideShowPrev() {
            var elm = $('.slider');
            if (elm.data('left') < -1000) return;
            elm.data('left',elm.data('left')-480);
            elm.css('left',elm.data('left')+'px');
        };
    </script>
